# macOS
.DS_Store
*.swp

# Logs
*.log
*.out
*.err

# Env / secrets (gelecekte API key kullanırsak)
.env
.env.*
*.key
*.pem

# Editor
.vscode/
.idea/
*~

# Obsidian — repo'ya gitmez (Obsidian vault iCloud'da ayrı yerde)
.obsidian/

# Eski "Cemal" referansları için backup'lar (varsa)
*.bak
